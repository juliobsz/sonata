<Window x:Class="Sonata.Desktop.Views.ConversationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="Sonata"
        Height="850"
        Width="1450"
        MinHeight="700"
        MinWidth="1150">
    <Window.Resources>
        <BooleanToVisibilityConverter
            x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="14,10"
                Background="#302E36"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Movement"
                           Margin="0,0,12,0"
                           Foreground="#AAA4B5" />
                <TextBlock Text="{Binding MovementName}"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    Background="#29272E"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Conversations"
                               Margin="4,2,4,10"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ui:Button Grid.Row="1"
                               Content="New conversation"
                               Margin="0,0,0,10"
                               Command="{Binding NewConversationCommand}" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Conversations}"
                             SelectedItem="{Binding CurrentConversation}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Conversation"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Id}"
                                               FontSize="10"
                                               Opacity="0.7"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="10"
                    Background="#29272E"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Messages"
                               Margin="4,2,4,10"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Messages}"
                             SelectedItem="{Binding SelectedMessage}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="4" CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#3B4652" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}"
                                                             Value="assistant">
                                                    <Setter Property="Background"
                                                            Value="#3A373F" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{Binding Content}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Sequence, StringFormat=Sequence {0}}"
                                                   Margin="0,5,0,0"
                                                   FontSize="10"
                                                   Opacity="0.55" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2"
                          Margin="0,10,0,0">
                        <ui:TextBox MinHeight="52"
                                    MaxHeight="150"
                                    Padding="12,10,52,10"
                                    Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    VerticalContentAlignment="Top"
                                    VerticalScrollBarVisibility="Auto"
                                    PreviewKeyDown="CommandInputPreviewKeyDown" />

                        <ui:Button x:Name="SendButton"
                                   Width="36"
                                   Height="36"
                                   Margin="0,0,6,6"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon ArrowUp32}"
                                   Command="{Binding SendCommand}"
                                   ToolTip="Send" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Padding="12"
                    Background="#29272E"
                    CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Governed Memory"
                                   FontSize="16"
                                   FontWeight="SemiBold" />

                        <TextBlock Text="Save selected user Message"
                                   Margin="0,16,0,5"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedMessage.Content, TargetNullValue=Select a persisted user Message.}"
                                   Padding="8"
                                   Background="#34313A"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Concise Memory claim"
                                   Margin="0,10,0,5" />
                        <TextBox Text="{Binding MemoryText, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="64"
                                 MaxLength="500"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap" />

                        <TextBlock Text="Type"
                                   Margin="0,10,0,5" />
                        <ComboBox ItemsSource="{Binding MemoryTypes}"
                                  SelectedItem="{Binding SelectedMemoryType}" />

                        <ui:Button Content="Save as Memory"
                                   Margin="0,10,0,0"
                                   Appearance="Primary"
                                   Command="{Binding SaveMemoryCommand}" />

                        <Separator Margin="0,18,0,14" />

                        <DockPanel>
                            <TextBlock Text="Memories"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left" />
                            <ui:Button Content="Refresh"
                                       HorizontalAlignment="Right"
                                       Command="{Binding RefreshMemoriesCommand}" />
                        </DockPanel>

                        <ListBox ItemsSource="{Binding Memories}"
                                 SelectedItem="{Binding SelectedMemory}"
                                 MinHeight="150"
                                 MaxHeight="230"
                                 Margin="0,8,0,0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Text}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="11">
                                            <Run Text="{Binding Type}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding LifecycleState}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding SourceNote.Excerpt}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Opacity="0.65"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Source Note"
                                   Margin="0,12,0,5"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedSourceExcerpt}"
                                   Padding="8"
                                   Background="#34313A"
                                   TextWrapping="Wrap" />

                        <ui:Button Content="Archive selected Memory"
                                   Margin="0,10,0,0"
                                   Command="{Binding RequestArchiveCommand}" />

                        <Border Margin="0,8,0,0"
                                Padding="10"
                                Background="#4A3428"
                                Visibility="{Binding IsArchiveConfirmationPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Archive removes this Memory from normal retrieval immediately."
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,8,0,0">
                                    <ui:Button Content="Confirm archive"
                                               Appearance="Danger"
                                               Margin="0,0,8,0"
                                               Command="{Binding ConfirmArchiveCommand}" />
                                    <ui:Button Content="Cancel"
                                               Command="{Binding CancelArchiveCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,18,0,14" />

                        <TextBlock Text="Latest Memory Diff"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MemoryDiffStatus}"
                                   Margin="0,4,0,6"
                                   Opacity="0.7"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding LatestMemoryDiff}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4,0,0"
                                            Padding="8"
                                            Background="#34313A"
                                            CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="11">
                                                <Run Text="{Binding Rank, StringFormat=Rank {0}}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding Type}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding Reason}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Margin="4,10,4,0"
                   Opacity="0.75"
                   TextWrapping="Wrap" />
    </Grid>
</Window>